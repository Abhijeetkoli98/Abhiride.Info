# Environment Variables Template for AbhiRide Backend

PORT=5000
NODE_ENV=production
DATABASE_URL="postgresql://abhiride_user:securepassword@localhost:5432/abhiride_db?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
REDIS_URL="redis://localhost:6379"

# Firebase Project Settings
FIREBASE_PROJECT_ID="abhiride"

# Third-Party Integrations
RAZORPAY_KEY_ID="rzp_live_samplekey"
RAZORPAY_KEY_SECRET="rzp_live_samplesecret"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# AbhiRide Root Environment Variables Template

# Frontend Environment Variables (Prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=abhiride.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=abhiride
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=abhiride.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Backend Environment Variables
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/abhiride?schema=public
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
